# Environment Variables Template
# Copy this file to .env and update with your values

# ====================================
# DATABASE CONFIGURATION
# ====================================
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_this_secure_password_12345
POSTGRES_DB=chatbot_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database connection string
DATABASE_URL=postgresql://chatbot:change_this_secure_password_12345@localhost:5432/chatbot_db

# ====================================
# BACKEND CONFIGURATION
# ====================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-something-random
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:3000

# API Configuration
OPENAI_API_KEY=your-openai-api-key-here
USE_MOCK_AI=True  # Set to False when using real OpenAI

# Rate Limiting
RATE_LIMIT=100/minute

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ====================================
# FRONTEND CONFIGURATION
# ====================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_ENV=development

# ====================================
# DOCKER CONFIGURATION
# ====================================
DOCKER_REGISTRY=localhost:5000
DOCKER_IMAGE_TAG=latest

# ====================================
# KUBERNETES CONFIGURATION
# ====================================
K8S_NAMESPACE=chatbot
K8S_REPLICAS_BACKEND=3
K8S_REPLICAS_FRONTEND=2

# ====================================
# AWS CONFIGURATION (for later)
# ====================================
AWS_REGION_CONSOLE=us-east-1
AWS_REGION_IAM=us-east-1
AWS_REGION_EKS=ap-southeast-2
AWS_REGION_ECR=ap-southeast-2
AWS_ACCOUNT_ID=868987408656
ECR_REGISTRY=868987408656.dkr.ecr.ap-southeast-2.amazonaws.com
EKS_CLUSTER_NAME=ai-chatbot-cluster
EKS_REGION=ap-southeast-2

# ====================================
# JENKINS CONFIGURATION (for later)
# ====================================
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_PASSWORD=change_this_password

# ====================================
# LOGGING
# ====================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ====================================
# MONITORING (for later)
# ====================================
PROMETHEUS_ENABLED=False
METRICS_PORT=9090
